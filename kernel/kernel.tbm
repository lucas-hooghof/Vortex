C_COMPILER(x86_64-elf-gcc)
CC_COMPILER(x86_64-elf-g++)
ASSEMBLER(nasm)
LINKER(x86_64-elf-ld)

FILES(*.cpp)

ADD_CCFLAGS(-Wall -Wextra -Wpedantic -Werror -ffreestanding-D%target% -I . -g)
ADD_LDFLAGS(-nostdlib -T linker.ld)



OUTPUT(kernel)
POSTBUILDCOMMAND(../scripts/CopyKernel.sh %workingdir%/%prefix%Vortex.hdd %workingdir%/%prefix%kernel)